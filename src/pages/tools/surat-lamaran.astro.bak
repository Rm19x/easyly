---
// src/pages/tools/surat-lamaran.astro
const title = "Generator Surat Lamaran Kerja AI-Ready - Easyly";
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    body { font-family: system-ui, sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 0; }
    header { background-color: #2c3e50; color: white; padding: 1.5rem; text-align: center; }
    .nav-back { display: inline-block; color: white; text-decoration: none; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid white; padding: 0.3rem 0.8rem; border-radius: 4px; }
    .nav-back:hover { background: rgba(255,255,255,0.1); }
    .container { max-width: 800px; margin: 2rem auto; padding: 0 1rem; }
    .card { background: white; border-radius: 8px; padding: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .form-group { margin-bottom: 1.2rem; }
    label { display: block; font-weight: bold; margin-bottom: 0.5rem; color: #2c3e50; }
    input, textarea, select { width: 100%; padding: 0.7rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 1rem; }
    textarea { resize: vertical; height: 100px; }
    .btn { display: block; width: 100%; background-color: #27ae60; color: white; border: none; padding: 0.8rem; border-radius: 4px; font-weight: bold; font-size: 1rem; cursor: pointer; text-align: center; }
    .btn:hover { background-color: #219653; }
    .result-box { margin-top: 2rem; display: none; }
    .output-area { background: #f9f9f9; border: 1px dashed #27ae60; padding: 1.5rem; border-radius: 4px; white-space: pre-wrap; font-family: 'Courier New', Courier, monospace; line-height: 1.6; }
    .btn-copy { background-color: #2980b9; margin-top: 1rem; }
    .btn-copy:hover { background-color: #2471a3; }
  </style>
</head>
<body>

  <header>
    <a href="/" class="nav-back">⬅ Kembali ke Beranda</a>
    <h1>📝 Generator Surat Lamaran Kerja</h1>
    <p>Buat draf surat lamaran kerja formal yang rapi secara instan</p>
  </header>

  <main class="container">
    <div class="card">
      <div class="form-group">
        <label for="nama">Nama Lengkap</label>
        <input type="text" id="nama" placeholder="Contoh: Muhammad Ridho" />
      </div>

      <div class="form-group">
        <label for="kontak">Nomor HP / Email / Alamat</label>
        <input type="text" id="kontak" placeholder="Contoh: 08123456789 | ridho@email.com | Jakarta" />
      </div>

      <div class="form-group">
        <label for="perusahaan">Nama Perusahaan Tujuan</label>
        <input type="text" id="perusahaan" placeholder="Contoh: PT. Teknologi Maju Mundur" />
      </div>

      <div class="form-group">
        <label for="posisi">Posisi yang Dilamar</label>
        <input type="text" id="posisi" placeholder="Contoh: Frontend Developer" />
      </div>

      <div class="form-group">
        <label for="pengalaman">Ringkasan Pengalaman / Keahlian Utama</label>
        <textarea id="pengalaman" placeholder="Contoh: Memiliki pengalaman 2 tahun di bidang web development, menguasai Astro, HTML, CSS, dan JavaScript. Pernah membangun 5 proyek web opensource."></textarea>
      </div>

      <button class="btn" id="generateBtn">Buat Surat Lamaran</button>

      <div class="result-box" id="resultBox">
        <label>Hasil Draf Surat Lamaran Kerja:</label>
        <div class="output-area" id="outputSurat"></div>
        <button class="btn btn-copy" id="copyBtn">Salin Teks Surat</button>
      </div>
    </div>
  </main>

  <script>
    const generateBtn = document.getElementById('generateBtn');
    const copyBtn = document.getElementById('copyBtn');
    const resultBox = document.getElementById('resultBox');
    const outputSurat = document.getElementById('outputSurat');

    generateBtn.addEventListener('click', () => {
      const nama = document.getElementById('nama').value || '[Nama Anda]';
      const kontak = document.getElementById('kontak').value || '[Kontak Anda]';
      const perusahaan = document.getElementById('perusahaan').value || '[Nama Perusahaan]';
      const posisi = document.getElementById('posisi').value || '[Posisi Jabatan]';
      const pengalaman = document.getElementById('pengalaman').value || '[Ringkasan keahlian dan pengalaman Anda]';
      
      const tanggalHariIni = new Date().toLocaleDateString('id-ID', {
        year: 'numeric',
        month: 'long',
        day: 'numeric'
      });

      const templateSurat = `Hal: Lamaran Pekerjaan - ${posisi}

Kepada Yth.
HRD ${perusahaan}
Di Tempat

Dengan hormat,

Sehubungan dengan informasi lowongan pekerjaan yang saya dapatkan, melalui surat ini saya bermaksud untuk mengajukan diri guna bergabung dengan ${perusahaan} sebagai ${posisi}.

Berikut adalah data singkat mengenai diri saya:
Nama: ${nama}
Kontak: ${kontak}

Latar belakang saya adalah seorang yang berkomitmen dan berdedikasi di bidang ini. ${pengalaman} Saya percaya keahlian dan minat besar saya akan mampu memberikan kontribusi positif bagi kemajuan perusahaan yang Bapak/Ibu pimpin.

Sebagai bahan pertimbangan, bersama surat ini saya juga melampirkan Curriculum Vitae (CV) serta portofolio pengerjaan proyek saya yang terbaru.

Demikian surat lamaran ini saya sampaikan. Besar harapan saya untuk diberikan kesempatan mengikuti tahapan wawancara agar dapat menjelaskan potensi diri saya secara lebih mendalam. Atas perhatian Bapak/Ibu, saya ucapkan terima kasih.

Hormat saya,


${nama}`;

      outputSurat.textContent = templateSurat;
      resultBox.style.display = 'block';
      resultBox.scrollIntoView({ behavior: 'smooth' });
    });

    copyBtn.addEventListener('click', () => {
      navigator.clipboard.writeText(outputSurat.textContent);
      alert('Surat lamaran berhasil disalin ke clipboard!');
    });
  </script>
</body>
</html>