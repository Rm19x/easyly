---
// src/pages/tools/resep-makanan.astro
const title = "Alat Pengonversi Skala Resep Makanan - Easyly";
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    body { font-family: system-ui, sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 0; display: flex; flex-direction: column; min-height: 100vh; }
    header { background-color: #2c3e50; color: white; padding: 1.5rem; text-align: center; }
    .nav-back { display: inline-block; color: white; text-decoration: none; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid white; padding: 0.3rem 0.8rem; border-radius: 4px; }
    .nav-back:hover { background: rgba(255,255,255,0.1); }
    .container { max-width: 700px; margin: 2rem auto; padding: 0 1rem; flex: 1; }
    .card { background: white; border-radius: 8px; padding: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .porsi-group { display: flex; gap: 1rem; margin-bottom: 1.5rem; }
    .form-group { flex: 1; }
    label { display: block; font-weight: bold; margin-bottom: 0.5rem; color: #2c3e50; }
    input, textarea { width: 100%; padding: 0.7rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 1rem; }
    textarea { height: 150px; resize: vertical; font-family: monospace; }
    .instructions { font-size: 0.85rem; color: #666; margin-top: -0.3rem; margin-bottom: 1rem; }
    .btn { display: block; width: 100%; background-color: #e67e22; color: white; border: none; padding: 0.8rem; border-radius: 4px; font-weight: bold; font-size: 1rem; cursor: pointer; text-align: center; }
    .btn:hover { background-color: #d35400; }
    .result-box { margin-top: 2rem; display: none; }
    .output-area { background: #fffcf9; border: 1px dashed #e67e22; padding: 1.5rem; border-radius: 4px; white-space: pre-wrap; font-family: monospace; line-height: 1.6; font-size: 1.05rem; }
    footer { background-color: #2c3e50; color: #bdc3c7; text-align: center; padding: 1rem; font-size: 0.9rem; margin-top: 2rem; }
    footer a { color: #3498db; text-decoration: none; font-weight: bold; }
    footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <header>
    <a href="/" class="nav-back">⬅ Kembali ke Beranda</a>
    <h1>🍳 Pengonversi Skala Resep Makanan</h1>
    <p>Ubah takaran bahan resep otomatis berdasarkan jumlah porsi target</p>
  </header>

  <main class="container">
    <div class="card">
      <div class="porsi-group">
        <div class="form-group">
          <label for="porsiAwal">Porsi Asli Resep</label>
          <input type="number" id="porsiAwal" value="2" min="1" />
        </div>
        <div class="form-group">
          <label for="porsiTarget">Porsi yang Diinginkan</label>
          <input type="number" id="porsiTarget" value="4" min="1" />
        </div>
      </div>

      <div class="form-group">
        <label for="bahanTeks">Daftar Bahan Makanan</label>
        <p class="instructions">Format: tuliskan angka jumlah di awal baris. Contoh:<br>200 gram tepung terigu<br>2 butir telur<br>1.5 sendok teh garam</p>
        <textarea id="bahanTeks" placeholder="200 gram tepung terigu&#10;2 butir telur&#10;1.5 sendok teh garam"></textarea>
      </div>

      <button class="btn" id="hitungBtn">Konversi Ukuran Resep</button>

      <div class="result-box" id="resultBox">
        <label>Bahan Setelah Disesuaikan:</label>
        <div class="output-area" id="outputBahan"></div>
      </div>
    </div>
  </main>

  <footer>
    <p>Developed with ❤️ by <strong>Mr.Rm19</strong> | <a href="https://github.com/Rm19x" target="_blank" rel="noopener noreferrer">github.com/Rm19x</a></p>
  </footer>

  <script>
    const hitungBtn = document.getElementById('hitungBtn');
    const resultBox = document.getElementById('resultBox');
    const outputBahan = document.getElementById('outputBahan');

    hitungBtn.addEventListener('click', () => {
      const porsiAwal = parseFloat(document.getElementById('porsiAwal').value) || 1;
      const porsiTarget = parseFloat(document.getElementById('porsiTarget').value) || 1;
      const bahanTeks = document.getElementById('bahanTeks').value;

      if (!bahanTeks.trim()) {
        alert('Silakan masukkan daftar bahan makanan terlebih dahulu.');
        return;
      }

      const faktorSkala = porsiTarget / porsiAwal;
      const barisBahan = bahanTeks.split('\n');
      let hasilKonversi = [];

      barisBahan.forEach(baris => {
        const match = baris.trim().match(/^([0-9\.]+)(.*)/);
        
        if (match) {
          const angkaAsli = parseFloat(match[1]);
          const teksSisa = match[2];
          
          if (!isNaN(angkaAsli)) {
            const angkaBaru = (angkaAsli * faktorSkala);
            const angkaFormat = Number(angkaBaru.toFixed(2)).toString().replace('.', ',');
            hasilKonversi.push(`${angkaFormat}${teksSisa}`);
          } else {
            hasilKonversi.push(baris);
          }
        } else {
          hasilKonversi.push(baris);
        }
      });

      outputBahan.textContent = hasilKonversi.join('\n');
      resultBox.style.display = 'block';
      resultBox.scrollIntoView({ behavior: 'smooth' });
    });
  </script>
</body>
</html>