---
// src/pages/tools/panduan-p3k.astro
const title = "Panduan Pertolongan Pertama (P3K) Interaktif - Easyly";
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    body { font-family: system-ui, sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 0; display: flex; flex-direction: column; min-height: 100vh; }
    header { background-color: #2c3e50; color: white; padding: 1.5rem; text-align: center; }
    .nav-back { display: inline-block; color: white; text-decoration: none; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid white; padding: 0.3rem 0.8rem; border-radius: 4px; }
    .nav-back:hover { background: rgba(255,255,255,0.1); }
    .container { max-width: 750px; margin: 2rem auto; padding: 0 1rem; flex: 1; }
    .card { background: white; border-radius: 8px; padding: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .form-group { margin-bottom: 1.5rem; }
    label { display: block; font-weight: bold; margin-bottom: 0.5rem; color: #2c3e50; }
    select { width: 100%; padding: 0.7rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 1rem; }
    .guide-box { display: none; margin-top: 1.5rem; border-left: 5px solid #e74c3c; background: #fdf2f2; padding: 1.5rem; border-radius: 4px; }
    .guide-title { font-size: 1.3rem; font-weight: bold; color: #c0392b; margin-top: 0; margin-bottom: 0.5rem; }
    .guide-danger { background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 0.8rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.9rem; font-weight: bold; }
    ol { margin: 0; padding-left: 1.2rem; line-height: 1.6; }
    li { margin-bottom: 0.8rem; font-size: 1rem; }
    .call-emergency { display: block; background-color: #e74c3c; color: white; text-align: center; padding: 0.8rem; border-radius: 4px; text-decoration: none; font-weight: bold; margin-top: 1.5rem; font-size: 1rem; }
    .call-emergency:hover { background-color: #c0392b; }
    footer { background-color: #2c3e50; color: #bdc3c7; text-align: center; padding: 1rem; font-size: 0.9rem; margin-top: 2rem; }
    footer a { color: #3498db; text-decoration: none; font-weight: bold; }
    footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <header>
    <a href="/" class="nav-back">⬅ Kembali ke Beranda</a>
    <h1>🚑 Panduan Pertolongan Pertama (P3K) Interaktif</h1>
    <p>Akses cepat dan interaktif panduan tindakan darurat medis awal di sekitar Anda</p>
  </header>

  <main class="container">
    <div class="card">
      
      <div class="form-group">
        <label for="emergencySelect">Pilih Kondisi Darurat Medis:</label>
        <select id="emergencySelect">
          <option value="">-- Silakan Pilih Kondisi --</option>
          <option value="lukabakar">Luka Bakar Ringan (Tersiram Air Panas/Kena Wajan)</option>
          <option value="tersedak">Orang Tersedak (Choking)</option>
          <option value="pingsan">Orang Pingsan / Hilang Kesadaran</option>
          <option value="mimisan">Mimisan (Keluar Darah dari Hidung)</option>
          <option value="gigitan">Gigitan Hewan (Serangga / Ular / Anjing)</option>
        </select>
      </div>

      <div class="guide-box" id="guideBox">
        <div class="guide-title" id="txtJudul"></div>
        <div class="guide-danger" id="txtPantangan"></div>
        <label style="margin-bottom: 0.5rem; display: block;">Langkah Tindakan P3K:</label>
        <ol id="stepList"></ol>
      </div>

      <a href="tel:112" class="call-emergency">📞 Hubungi Ambulans / Nomor Darurat (112)</a>

    </div>
  </main>

  <footer>
    <p>Developed with ❤️ by <strong>Mr.Rm19</strong> | <a href="https://github.com/Rm19x" target="_blank" rel="noopener noreferrer">github.com/Rm19x</a></p>
  </footer>

  <script>
    // Database Panduan Interaktif
    const dbP3K = {
      lukabakar: {
        judul: "🔥 Penanganan Luka Bakar Ringan",
        pantangan: "⚠️ JANGAN mengoleskan odol/pasta gigi, kecap, mentega, atau es batu langsung ke area luka karena bisa merusak jaringan kulit dan memicu infeksi!",
        langkah: [
          "Segera basuh area luka dengan air mengalir bersuhu normal (keran) selama minimal 10-15 menit.",
          "Lepaskan perhiasan atau pakaian di sekitar luka secara perlahan sebelum area tersebut membengkak.",
          "Tutup luka secara longgar menggunakan kain kasa steril yang bersih.",
          "Jika muncul lepuhan berair, jangan sengaja dipecahkan agar kulit dalam tetap terlindungi.",
          "Minum obat pereda nyeri jika diperlukan, dan segera temui dokter jika luka bakar meluas."
        ]
      },
      tersedak: {
        judul: "🍞 Penanganan Orang Tersedak (Dewasa)",
        pantangan: "⚠️ JANGAN memberikan minum kepada orang yang sedang tersedak parah sebelum sumbatan benda asingnya berhasil keluar!",
        langkah: [
          "Posisikan diri Anda berdiri di belakang korban.",
          "Condongkan tubuh korban sedikit ke depan, berikan 5 tepukan kuat di punggung di antara tulang belikat menggunakan pangkal tangan Anda.",
          "Jika belum keluar, lakukan Abdominal Thrusts (Metode Heimlich): Lingkarkan tangan Anda di pinggang korban.",
          "Kepalkan salah satu tangan, letakkan sedikit di atas pusar korban. Genggam kepalan itu dengan tangan satunya.",
          "Tekan perut korban ke arah dalam dan atas secara cepat dan kuat sebanyak 5 kali.",
          "Ulangi siklus ini sampai benda asing keluar atau bantuan medis tiba."
        ]
      },
      pingsan: {
        judul: "💤 Penanganan Orang Pingsan",
        pantangan: "⚠️ JANGAN memberi makan, minum, atau menyiramkan air ke wajah orang yang sedang pingsan karena berisiko menyumbat saluran napas!",
        langkah: [
          "Baringkan korban secara telentang di tempat yang aman, rata, dan sejuk.",
          "Tinggikan posisi kaki korban sekitar 30 cm di atas permukaan jantung menggunakan bantal atau barang lain agar aliran darah kembali lancar ke otak.",
          "Longgarkan pakaian ketat korban (seperti kerah kancing baju, dasi, atau sabuk pinggang).",
          "Berikan ruang udara yang cukup, pastikan orang sekitar tidak berkerumun mengerumuni korban.",
          "Ketika korban sadar, biarkan tetap berbaring sejenak sebelum perlahan dibantu untuk duduk."
        ]
      },
      mimisan: {
        judul: "🩸 Penanganan Mimisan",
        pantangan: "⚠️ JANGAN menengadahkan kepala ke belakang! Hal ini menyebabkan darah mengalir ke tenggorokan dan berisiko masuk ke saluran napas atau memicu muntah.",
        langkah: [
          "Minta korban untuk duduk tegak dan condongkan tubuh sedikit ke depan.",
          "Jepit bagian cuping hidung (bagian yang lunak) menggunakan ibu jari dan jari telunjuk selama 10 menit tanpa putus.",
          "Bernapaslah melalui mulut selama hidung ditekan.",
          "Kompres dingin pada area pangkal hidung untuk membantu mempersempit pembuluh darah dan menghentikan pendarahan.",
          "Jika mimisan tidak berhenti setelah 20 menit, segera bawa ke puskesmas/klinik terdekat."
        ]
      },
      gigitan: {
        judul: "🐍 Penanganan Gigitan / Sengatan Hewan",
        pantangan: "⚠️ Khusus gigitan ular: JANGAN menghisap racun dengan mulut, jangan diikat terlalu kencang (torniket), dan jangan banyak menggerakkan anggota tubuh yang digigit!",
        langkah: [
          "Cuci area gigitan sesegera mungkin dengan air mengalir dan sabun selama 10-15 menit untuk membunuh bakteri/virus.",
          "Jika disengat lebah, cabut sengat yang tertinggal di kulit secara perlahan menggunakan benda datar seperti kartu ATM.",
          "Khusus gigitan ular, lakukan imobilisasi: pasang bidai kayu/kain longgar agar bagian tubuh yang tergigit tidak bergerak (memperlambat penyebaran bisa).",
          "Tutup luka dengan kain bersih atau kasa steril.",
          "Segera bawa ke fasilitas kesehatan terdekat untuk mendapatkan Serum Anti-Bisa Ular (SABU) atau suntikan Anti-Tetanus/Rabies."
        ]
      }
    };

    const emergencySelect = document.getElementById('emergencySelect');
    const guideBox = document.getElementById('guideBox');
    const txtJudul = document.getElementById('txtJudul');
    const txtPantangan = document.getElementById('txtPantangan');
    const stepList = document.getElementById('stepList');

    emergencySelect.addEventListener('change', () => {
      const selectedValue = emergencySelect.value;
      
      if (!selectedValue) {
        guideBox.style.display = 'none';
        return;
      }

      const data = dbP3K[selectedValue];
      
      // Isi konten interaktif
      txtJudul.textContent = data.judul;
      txtPantangan.textContent = data.pantangan;
      
      // Reset dan isi ulang list langkah-langkah
      stepList.innerHTML = '';
      data.langkah.forEach(step => {
        let li = document.createElement('li');
        li.textContent = step;
        stepList.appendChild(li);
      });

      // Tampilkan box dengan transisi mulus
      guideBox.style.display = 'block';
      guideBox.scrollIntoView({ behavior: 'smooth' });
    });
  </script>
</body>
</html>