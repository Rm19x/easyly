---
// src/pages/tools/sisa-kulkas.astro
const title = "Generator Ide Masakan dari Bahan Sisa Kulkas - Easyly";
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    body { font-family: system-ui, sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 0; display: flex; flex-direction: column; min-height: 100vh; }
    header { background-color: #2c3e50; color: white; padding: 1.5rem; text-align: center; }
    .nav-back { display: inline-block; color: white; text-decoration: none; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid white; padding: 0.3rem 0.8rem; border-radius: 4px; }
    .nav-back:hover { background: rgba(255,255,255,0.1); }
    .container { max-width: 700px; margin: 2rem auto; padding: 0 1rem; flex: 1; }
    .card { background: white; border-radius: 8px; padding: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .ingredients-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 0.8rem; margin: 1.5rem 0; }
    .ingredient-item { display: flex; align-items: center; gap: 0.5rem; background: #f8f9fa; padding: 0.6rem; border-radius: 6px; border: 1px solid #e9ecef; cursor: pointer; transition: background 0.2s; }
    .ingredient-item:hover { background: #e9ecef; }
    .ingredient-item input { width: 18px; height: 18px; cursor: pointer; }
    label { font-weight: bold; color: #2c3e50; font-size: 1.05rem; }
    .btn { display: block; width: 100%; background-color: #27ae60; color: white; border: none; padding: 0.8rem; border-radius: 4px; font-weight: bold; font-size: 1rem; cursor: pointer; text-align: center; margin-top: 1rem; }
    .btn:hover { background-color: #219653; }
    .result-box { margin-top: 2rem; display: none; }
    .recipe-card { background: #fffdf5; border-left: 5px solid #f39c12; padding: 1.2rem; border-radius: 4px; margin-bottom: 1rem; border: 1px solid #fdedec; }
    .recipe-title { font-size: 1.15rem; font-weight: bold; color: #d35400; margin: 0 0 0.5rem 0; }
    .recipe-match { font-size: 0.85rem; color: #27ae60; font-weight: bold; margin-bottom: 0.5rem; }
    .no-recipe { text-align: center; color: #7f8c8d; padding: 2rem; font-style: italic; }
    footer { background-color: #2c3e50; color: #bdc3c7; text-align: center; padding: 1rem; font-size: 0.9rem; margin-top: 2rem; }
    footer a { color: #3498db; text-decoration: none; font-weight: bold; }
    footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <header>
    <a href="/" class="nav-back">⬅ Kembali ke Beranda</a>
    <h1>🍳 Generator Ide Masakan Sisa Kulkas</h1>
    <p>Centang bahan yang kamu miliki, dan kami carikan ide resep makanan nusantara yang cocok!</p>
  </header>

  <main class="container">
    <div class="card">
      
      <label>Pilih Bahan yang Tersedia di Kulkas Anda:</label>
      <div class="ingredients-grid" id="ingredientsGrid">
        </div>

      <button class="btn" id="cariResepBtn">Rekomendasikan Menu Masakan</button>

      <div class="result-box" id="resultBox">
        <label style="margin-bottom: 1rem; display: block;">💡 Rekomendasi Menu Masakan yang Bisa Dibuat:</label>
        <div id="recipeContainer"></div>
      </div>

    </div>
  </main>

  <footer>
    <p>Developed with ❤️ by <strong>Mr.Rm19</strong> | <a href="https://github.com/Rm19x" target="_blank" rel="noopener noreferrer">github.com/Rm19x</a></p>
  </footer>

  <script>
    // Daftar Bahan yang sering tersisa di kulkas Indonesia
    const daftarBahan = [
      "Telur", "Nasi Dingin", "Ayam", "Tahu", "Tempe", 
      "Mie Instan", "Bawang Merah", "Cabai", "Kangkung", "Wortel", 
      "Sosis/Bakso", "Kentang", "Kecap Manis", "Santan"
    ];

    // Database Resep Makanan Berdasarkan Bahan Utama
    const dbResep = [
      {
        nama: "Nasi Goreng Kampung Sederhana",
        bahanDibutuhkan: ["Nasi Dingin", "Telur", "Bawang Merah", "Cabai"],
        cara: "Haluskan bawang dan cabai. Tumis hingga harum, masukkan telur lalu urak-arik. Masukkan nasi dingin, tambahkan kecap manis, garam, dan penyedap rasa. Aduk rata hingga matang."
      },
      {
        nama: "Orek Tempe Kecap Pedas",
        bahanDibutuhkan: ["Tempe", "Bawang Merah", "Cabai", "Kecap Manis"],
        cara: "Potong tempe kotak kecil lalu goreng hingga setengah kering. Tumis bawang merah dan cabai iris. Masukkan tempe, tambahkan kecap manis, sedikit air, garam, dan gula. Masak hingga meresap."
      },
      {
        nama: "Tumis Kangkung Belacan",
        bahanDibutuhkan: ["Kangkung", "Bawang Merah", "Cabai"],
        cara: "Tumis bawang merah, cabai, dan sedikit terasi sampai harum. Masukkan kangkung yang sudah dicuci bersih. Tambahkan garam dan gula, masak dengan api besar sebentar saja agar tetap renyah."
      },
      {
        nama: "Tahu Ayam Kecap Kuah",
        bahanDibutuhkan: ["Tahu", "Ayam", "Bawang Merah", "Kecap Manis"],
        cara: "Potong ayam dan tahu. Tumis bawang merah iris hingga layu. Masukkan potongan ayam sampai berubah warna, masukkan tahu, beri kecap manis, garam, merica, dan secukupnya air. Rebus hingga kuah menyusut."
      },
      {
        nama: "Mie Instan Nyemek Spesial",
        bahanDibutuhkan: ["Mie Instan", "Telur", "Cabai", "Sosis/Bakso"],
        cara: "Rebus mie instan setengah matang, tiriskan. Tumis irisan cabai dan sosis/bakso. Masukkan sedikit air, bumbu mie instan, lalu pecahkan telur dan aduk rata hingga kuah mengental. Masukkan mie, masak sebentar."
      },
      {
        nama: "Sup Bakso Wortel Kentang",
        bahanDibutuhkan: ["Sosis/Bakso", "Wortel", "Kentang", "Bawang Merah"],
        cara: "Didihkan air. Tumis bawang merah halus, masukkan ke dalam air rebusan. Masukkan wortel dan kentang potong terlebih dahulu. Jika sudah agak empuk, masukkan bakso. Beri garam, gula, dan merica bubuk."
      }
    ];

    const ingredientsGrid = document.getElementById('ingredientsGrid');
    const cariResepBtn = document.getElementById('cariResepBtn');
    const resultBox = document.getElementById('resultBox');
    const recipeContainer = document.getElementById('recipeContainer');

    // Render daftar checkbox bahan makanan ke UI
    daftarBahan.forEach((bahan, idx) => {
      const div = document.createElement('div');
      div.className = "ingredient-item";
      div.innerHTML = `
        <input type="checkbox" id="bahan_${idx}" value="${bahan}">
        <label for="bahan_${idx}" style="font-weight:normal; font-size:0.95rem; cursor:pointer;">${bahan}</label>
      `;
      ingredientsGrid.appendChild(div);
    });

    cariResepBtn.addEventListener('click', () => {
      // Ambil semua bahan yang dicentang user
      const checkboxes = document.querySelectorAll('#ingredientsGrid input[type="checkbox"]:checked');
      const bahanTerpilih = Array.from(checkboxes).map(cb => cb.value);

      if (bahanTerpilih.length === 0) {
        alert("Silakan pilih minimal 1 atau 2 bahan makanan yang ada di kulkasmu!");
        return;
      }

      recipeContainer.innerHTML = "";
      let ditemukan = false;

      // Filter resep yang bahannya cocok dengan pilihan user
      dbResep.forEach(resep => {
        // Cek berapa banyak bahan resep yang berhasil terpenuhi oleh kulkas user
        const cocokBahan = resep.bahanDibutuhkan.filter(b => bahanTerpilih.includes(b));
        
        // Tampilkan resep jika minimal ada 2 bahan utama yang cocok atau jika total bahan resep sedikit, minimal 1 cocok
        if (cocokBahan.length >= Math.min(2, resep.bahanDibutuhkan.length)) {
          ditemukan = true;

          const card = document.createElement('div');
          card.className = "recipe-card";
          card.innerHTML = `
            <div class="recipe-title">🍽️ ${resep.nama}</div>
            <div class="recipe-match">Bahan kamu yang cocok: ${cocokBahan.join(', ')}</div>
            <div style="font-size:0.9rem; color:#555; line-height:1.5;">
              <strong>Bahan Utama:</strong> ${resep.bahanDibutuhkan.join(', ')}<br>
              <strong>Cara Memasak:</strong> ${resep.cara}
            </div>
          `;
          recipeContainer.appendChild(card);
        }
      });

      if (!ditemukan) {
        recipeContainer.innerHTML = `<div class="no-recipe">Maaf, kombinasi bahan kulkas Anda belum cocok dengan database kami. Coba centang bahan dasar tambahan seperti Telur, Cabai, atau Bawang Merah!</div>`;
      }

      resultBox.style.display = 'block';
      resultBox.scrollIntoView({ behavior: 'smooth' });
    });
  </script>
</body>
</html>