---
// src/pages/tools/generator-password.astro
const title = "Generator Password Super Aman & Pengecek Kekuatan Sandi - Easyly";
---

<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <style>
    body { font-family: system-ui, sans-serif; background-color: #f4f7f6; color: #333; margin: 0; padding: 0; display: flex; flex-direction: column; min-height: 100vh; }
    header { background-color: #2c3e50; color: white; padding: 1.5rem; text-align: center; }
    .nav-back { display: inline-block; color: white; text-decoration: none; margin-bottom: 1rem; font-size: 0.9rem; border: 1px solid white; padding: 0.3rem 0.8rem; border-radius: 4px; }
    .nav-back:hover { background: rgba(255,255,255,0.1); }
    .container { max-width: 600px; margin: 2rem auto; padding: 0 1rem; flex: 1; }
    .card { background: white; border-radius: 8px; padding: 2rem; box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
    .form-group { margin-bottom: 1.2rem; }
    label { display: block; font-weight: bold; margin-bottom: 0.5rem; color: #2c3e50; }
    input[type="text"] { width: 100%; padding: 0.7rem; border: 1px solid #ccc; border-radius: 4px; box-sizing: border-box; font-size: 1.1rem; text-align: center; font-family: monospace; background-color: #f9f9f9; }
    .range-group { display: flex; align-items: center; gap: 1rem; }
    input[type="range"] { flex: 1; }
    .checkbox-group { display: grid; grid-template-columns: 1fr 1fr; gap: 0.8rem; margin: 1rem 0; }
    .checkbox-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.95rem; }
    .checkbox-item input { width: 18px; height: 18px; cursor: pointer; }
    .strength-meter { height: 8px; width: 100%; background-color: #ddd; border-radius: 4px; margin-top: 0.5rem; overflow: hidden; }
    .strength-bar { height: 100%; width: 0%; transition: width 0.3s, background-color: 0.3s; }
    .strength-text { font-size: 0.85rem; font-weight: bold; margin-top: 0.3rem; text-align: right; color: #666; }
    .btn { display: block; width: 100%; border: none; padding: 0.8rem; border-radius: 4px; font-weight: bold; font-size: 1rem; cursor: pointer; text-align: center; margin-top: 1rem; }
    .btn-generate { background-color: #1abc9c; color: white; }
    .btn-generate:hover { background-color: #16a085; }
    .btn-copy { background-color: #34495e; color: white; }
    .btn-copy:hover { background-color: #2c3e50; }
    footer { background-color: #2c3e50; color: #bdc3c7; text-align: center; padding: 1rem; font-size: 0.9rem; margin-top: 2rem; }
    footer a { color: #3498db; text-decoration: none; font-weight: bold; }
    footer a:hover { text-decoration: underline; }
  </style>
</head>
<body>

  <header>
    <a href="/" class="nav-back">⬅ Kembali ke Beranda</a>
    <h1>🔒 Generator & Pengecek Password</h1>
    <p>Buat password super kuat yang sulit diretas dan cek kekuatannya langsung</p>
  </header>

  <main class="container">
    <div class="card">
      
      <div class="form-group">
        <label>Password Dihasilkan / Diketik</label>
        <input type="text" id="passwordInput" placeholder="Klik buat atau ketik di sini..." />
        <div class="strength-meter">
          <div class="strength-bar" id="strengthBar"></div>
        </div>
        <div class="strength-text" id="strengthText">Kekuatan: -</div>
      </div>

      <div class="form-group">
        <div class="range-group">
          <label for="lengthInput">Panjang Karakter: <span id="lengthVal">12</span></label>
        </div>
        <input type="range" id="lengthInput" min="6" max="30" value="12" />
      </div>

      <label>Opsi Karakter:</label>
      <div class="checkbox-group">
        <div class="checkbox-item">
          <input type="checkbox" id="includeUppercase" checked />
          <label for="includeUppercase" style="margin:0; font-weight:normal;">Huruf Besar (A-Z)</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="includeLowercase" checked />
          <label for="includeLowercase" style="margin:0; font-weight:normal;">Huruf Kecil (a-z)</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="includeNumbers" checked />
          <label for="includeNumbers" style="margin:0; font-weight:normal;">Angka (0-9)</label>
        </div>
        <div class="checkbox-item">
          <input type="checkbox" id="includeSymbols" checked />
          <label for="includeSymbols" style="margin:0; font-weight:normal;">Simbol (!@#$...)</label>
        </div>
      </div>

      <button class="btn btn-generate" id="generateBtn">Buat Password Aman</button>
      <button class="btn btn-copy" id="copyBtn">Salin Password</button>

    </div>
  </main>

  <footer>
    <p>Developed with ❤️ by <strong>Mr.Rm19</strong> | <a href="https://github.com/Rm19x" target="_blank" rel="noopener noreferrer">github.com/Rm19x</a></p>
  </footer>

  <script>
    const passwordInput = document.getElementById('passwordInput');
    const lengthInput = document.getElementById('lengthInput');
    const lengthVal = document.getElementById('lengthVal');
    const includeUppercase = document.getElementById('includeUppercase');
    const includeLowercase = document.getElementById('includeLowercase');
    const includeNumbers = document.getElementById('includeNumbers');
    const includeSymbols = document.getElementById('includeSymbols');
    const generateBtn = document.getElementById('generateBtn');
    const copyBtn = document.getElementById('copyBtn');
    const strengthBar = document.getElementById('strengthBar');
    const strengthText = document.getElementById('strengthText');

    const uppercaseChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
    const lowercaseChars = "abcdefghijklmnopqrstuvwxyz";
    const numberChars = "0123456789";
    const symbolChars = "!@#$%^&*()_+~`|}{[]:;?><,./-=";

    // Update teks angka panjang karakter saat slider digeser
    lengthInput.addEventListener('input', () => {
      lengthVal.textContent = lengthInput.value;
    });

    // Fungsi membuat password acak
    generateBtn.addEventListener('click', () => {
      let characterPool = "";
      if (includeUppercase.checked) characterPool += uppercaseChars;
      if (includeLowercase.checked) characterPool += lowercaseChars;
      if (includeNumbers.checked) characterPool += numberChars;
      if (includeSymbols.checked) characterPool += symbolChars;

      if (characterPool === "") {
        alert("Silakan pilih minimal satu opsi karakter!");
        return;
      }

      let generatedPassword = "";
      const passwordLength = parseInt(lengthInput.value);

      for (let i = 0; i < passwordLength; i++) {
        const randomIndex = Math.floor(Math.random() * characterPool.length);
        generatedPassword += characterPool[randomIndex];
      }

      passwordInput.value = generatedPassword;
      checkPasswordStrength(generatedPassword);
    });

    // Cek kekuatan ketika pengguna mengetik manual
    passwordInput.addEventListener('input', () => {
      checkPasswordStrength(passwordInput.value);
    });

    function checkPasswordStrength(password) {
      if (!password) {
        strengthBar.style.width = "0%";
        strengthText.textContent = "Kekuatan: -";
        return;
      }

      let score = 0;
      if (password.length >= 8) score++;
      if (password.length >= 14) score++;
      if (/[A-Z]/.test(password)) score++;
      if (/[a-z]/.test(password)) score++;
      if (/[0-9]/.test(password)) score++;
      if (/[^A-Za-z0-9]/.test(password)) score++;

      let percentage = (score / 6) * 100;
      strengthBar.style.width = `${percentage}%`;

      if (score <= 2) {
        strengthBar.style.backgroundColor = "#e74c3c"; // Merah
        strengthText.textContent = "Kekuatan: Lemah 😟";
        strengthText.style.color = "#e74c3c";
      } else if (score <= 4) {
        strengthBar.style.backgroundColor = "#f1c40f"; // Kuning
        strengthText.textContent = "Kekuatan: Sedang 😐";
        strengthText.style.color = "#f1c40f";
      } else {
        strengthBar.style.backgroundColor = "#2ecc71"; // Hijau
        strengthText.textContent = "Kekuatan: Sangat Kuat! 😎";
        strengthText.style.color = "#2ecc71";
      }
    }

    // Fungsi salin teks
    copyBtn.addEventListener('click', () => {
      if (!passwordInput.value) {
        alert('Buat atau ketik password terlebih dahulu sebelum menyalin.');
        return;
      }
      navigator.clipboard.writeText(passwordInput.value);
      alert('Password berhasil disalin!');
    });
  </script>
</body>
</html>